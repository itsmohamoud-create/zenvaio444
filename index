<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Zenvaio — AI Automation Systems for Growing Businesses</title>
<meta name="description" content="Zenvaio designs and manages AI-powered automation systems tailored to your business — so every lead gets a response, every appointment gets booked, and you can focus on the work you love." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
<style>
:root {
  --navy: #0D1F2D;
  --navy-deep: #052535;
  --teal: #00C896;
  --teal-light: #00E8AE;
  --teal-dark: #009A72;
  --pale-teal: #E0FAF4;
  --teal-border: #C8EFE6;
  --page-green: #F0FAF7;
  --text-muted: #5A7A8A;
  --green-dark: #057A5A;
  --white: #FFFFFF;
  --hero-grad: linear-gradient(135deg, #0D1F2D 0%, #052535 100%);
  --cta-grad: linear-gradient(135deg, #00C896 0%, #009A72 100%);
  --font: 'Plus Jakarta Sans', Arial, sans-serif;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: var(--font); color: var(--navy); background: var(--white); overflow-x: hidden; }

/* ANNOUNCEMENT BAR */
.announce-bar {
  background: var(--navy-deep);
  border-bottom: 1px solid rgba(0,200,150,0.2);
  padding: 9px 20px;
  text-align: center;
  font-size: 13px;
  color: rgba(255,255,255,0.75);
  display: flex; align-items: center; justify-content: center; gap: 10px;
  flex-wrap: wrap;
}
.announce-bar .stars { color: #FFD700; letter-spacing: 2px; }
.announce-bar a { color: var(--teal); text-decoration: none; font-weight: 700; }
.announce-bar a:hover { color: var(--teal-light); }

/* NAV */
nav {
  position: sticky; top: 0; z-index: 1000;
  height: 64px; background: var(--navy);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 60px;
  border-bottom: 1px solid rgba(0,200,150,0.1);
}
.nav-logo {
  display: flex; align-items: center; gap: 10px;
  text-decoration: none;
}
.nav-logo-svg {
  width: 40px; height: 40px; flex-shrink: 0;
}
.nav-logo-text {
  font-size: 20px; font-weight: 800; color: var(--white);
  letter-spacing: 3px; text-transform: uppercase;
}
.nav-logo-text span { color: var(--teal); }

.nav-center {
  display: flex; align-items: center; gap: 6px; list-style: none;
}
.nav-center li { position: relative; }
.nav-center li > a,
.nav-center li > button {
  font-family: var(--font); font-size: 14px; font-weight: 500;
  color: rgba(255,255,255,0.70); text-decoration: none;
  background: none; border: none; cursor: pointer;
  padding: 8px 14px; border-radius: 6px;
  display: flex; align-items: center; gap: 5px;
  transition: color .2s, background .2s; white-space: nowrap;
}
.nav-center li > a:hover, .nav-center li > button:hover {
  color: var(--white); background: rgba(255,255,255,0.06);
}
.chevron {
  width: 10px; height: 10px;
  border-right: 2px solid currentColor; border-bottom: 2px solid currentColor;
  transform: rotate(45deg) translateY(-2px); transition: transform .2s; display: inline-block;
}
.nav-center li:hover .chevron { transform: rotate(225deg) translateY(-2px); }
.dropdown {
  position: absolute; top: calc(100% + 8px); left: 50%;
  transform: translateX(-50%) translateY(-6px);
  min-width: 260px; background: var(--navy);
  border: 1px solid rgba(0,200,150,0.15);
  border-radius: 12px; padding: 8px;
  opacity: 0; pointer-events: none;
  transition: opacity .2s, transform .2s;
  box-shadow: 0 20px 60px rgba(0,0,0,0.4);
}
.nav-center li:hover .dropdown {
  opacity: 1; pointer-events: all; transform: translateX(-50%) translateY(0);
}
.dropdown a {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 10px 12px; border-radius: 8px; text-decoration: none; transition: background .15s;
}
.dropdown a:hover { background: rgba(255,255,255,0.06); }
.dd-icon {
  width: 32px; height: 32px; background: rgba(0,200,150,0.12);
  border-radius: 8px; display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; font-size: 14px;
}
.dd-text strong { display: block; font-size: 13px; font-weight: 700; color: var(--white); margin-bottom: 2px; }
.dd-text span { font-size: 11.5px; color: rgba(255,255,255,0.45); line-height: 1.4; }

.nav-right { display: flex; align-items: center; gap: 10px; }
.btn-nav {
  font-family: var(--font); font-size: 14px; font-weight: 700;
  background: var(--teal); color: var(--navy-deep);
  border: none; cursor: pointer; padding: 9px 20px; border-radius: 7px;
  transition: opacity .2s, transform .1s; text-decoration: none; white-space: nowrap;
}
.btn-nav:hover { opacity: .88; transform: translateY(-1px); }

.hamburger {
  display: none; flex-direction: column; gap: 5px;
  background: none; border: none; cursor: pointer; padding: 6px;
}
.hamburger span { width: 22px; height: 2px; background: rgba(255,255,255,0.7); border-radius: 2px; transition: .3s; }

/* HERO */
.hero {
  background: var(--hero-grad);
  padding: 100px 60px 110px;
  text-align: center; position: relative; overflow: hidden;
}
.hero::before, .hero::after {
  content: ''; position: absolute; border-radius: 50%; pointer-events: none;
}
.hero::before {
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(0,200,150,0.07) 0%, transparent 70%);
  right: -150px; top: -150px;
}
.hero::after {
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(0,200,150,0.05) 0%, transparent 70%);
  left: -100px; bottom: -100px;
}
.hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(0,200,150,0.12); border: 1px solid rgba(0,200,150,0.30);
  color: var(--teal-light); font-size: 11px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase;
  padding: 7px 16px; border-radius: 99px; margin-bottom: 32px;
}
.hero-badge::before {
  content: ''; width: 6px; height: 6px;
  background: var(--teal); border-radius: 50%; animation: pulse 2s infinite;
}
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(1.4)} }
.hero h1 {
  font-size: clamp(36px, 5vw, 54px); font-weight: 800; color: var(--white);
  line-height: 1.15; max-width: 820px; margin: 0 auto 20px; letter-spacing: -1px;
}
.hero h1 .accent { color: var(--teal); }
.hero-sub {
  font-size: 17px; color: rgba(255,255,255,0.52);
  max-width: 560px; margin: 0 auto 44px; line-height: 1.8; font-weight: 400;
}
.hero-btns { display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; }
.btn-primary {
  font-family: var(--font); font-size: 15px; font-weight: 700;
  background: var(--teal); color: var(--navy-deep);
  border: none; cursor: pointer; padding: 15px 34px; border-radius: 8px;
  transition: opacity .2s, transform .15s; text-decoration: none; display: inline-block;
}
.btn-primary:hover { opacity: .88; transform: translateY(-2px); }
.btn-secondary {
  font-family: var(--font); font-size: 15px; font-weight: 600;
  background: transparent; color: var(--white);
  border: 1px solid rgba(255,255,255,0.22); cursor: pointer;
  padding: 15px 34px; border-radius: 8px;
  transition: background .2s, border-color .2s; text-decoration: none; display: inline-block;
}
.btn-secondary:hover { background: rgba(255,255,255,0.07); border-color: rgba(255,255,255,0.4); }

.trusted-bar {
  background: rgba(255,255,255,0.05); border-top: 1px solid rgba(255,255,255,0.08);
  margin-top: 60px; padding-top: 48px;
  display: flex; flex-direction: column; align-items: center; gap: 10px;
}
.trusted-label { font-size: 13px; color: rgba(255,255,255,0.45); font-weight: 600; letter-spacing: 1px; }
.stars-row { color: #FFD700; font-size: 18px; letter-spacing: 4px; }
.trusted-text { font-size: 13px; color: rgba(255,255,255,0.35); }

.hero-stats {
  display: flex; justify-content: center; gap: 48px;
  margin-top: 32px; padding-top: 32px;
  border-top: 1px solid rgba(255,255,255,0.08); flex-wrap: wrap;
}
.stat-item { text-align: center; }
.stat-number { font-size: 32px; font-weight: 800; color: var(--teal); display: block; letter-spacing: -1px; }
.stat-label { font-size: 13px; color: rgba(255,255,255,0.45); margin-top: 4px; font-weight: 500; }

/* REVENUE ALERT */
.revenue-alert {
  background: var(--navy-deep);
  padding: 80px 60px; text-align: center;
}
.revenue-alert h2 {
  font-size: clamp(24px,3.5vw,36px); font-weight: 800; color: var(--white);
  margin-bottom: 14px; letter-spacing: -0.5px; line-height: 1.2;
}
.revenue-alert > p {
  font-size: 16px; color: rgba(255,255,255,0.5);
  max-width: 520px; margin: 0 auto 48px; line-height: 1.7;
}
.revenue-stats {
  display: flex; justify-content: center; gap: 48px; flex-wrap: wrap; margin-bottom: 48px;
}
.revenue-stat { text-align: center; }
.revenue-stat-number { font-size: 44px; font-weight: 800; color: var(--teal); display: block; letter-spacing: -2px; }
.revenue-stat-label { font-size: 14px; color: rgba(255,255,255,0.5); margin-top: 6px; }

/* ZEN DEMO */
.ai-demo {
  background: var(--navy); padding: 80px 60px; text-align: center;
}
.ai-demo-label {
  font-size: 11px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--teal); margin-bottom: 16px;
}
.ai-demo h2 {
  font-size: clamp(24px,3.5vw,36px); font-weight: 800; color: var(--white);
  max-width: 640px; margin: 0 auto 14px; letter-spacing: -0.5px; line-height: 1.2;
}
.ai-demo-sub {
  font-size: 16px; color: rgba(255,255,255,0.45); max-width: 480px; margin: 0 auto 48px; line-height: 1.7;
}
.voice-agent-card {
  max-width: 480px; margin: 0 auto;
  background: rgba(255,255,255,0.04); border: 1px solid rgba(0,200,150,0.2);
  border-radius: 20px; padding: 36px 32px;
}
.voice-agent-header {
  display: flex; align-items: center; gap: 16px; margin-bottom: 24px;
}
.voice-avatar {
  width: 56px; height: 56px; background: rgba(0,200,150,0.15);
  border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px;
}
.voice-info h3 { font-size: 16px; font-weight: 700; color: var(--white); }
.voice-info p { font-size: 13px; color: rgba(255,255,255,0.4); margin-top: 2px; }
.retell-orb-wrap {
  display: flex; flex-direction: column; align-items: center; gap: 16px;
  padding: 24px 0 8px;
}
.retell-orb-wrap iframe { border-radius: 50%; overflow: hidden; }
.play-hint { font-size: 12px; color: rgba(255,255,255,0.3); margin-top: 8px; }

/* LOGOS TICKER */
.logos-section {
  background: var(--page-green);
  border-top: 1px solid var(--teal-border);
  border-bottom: 1px solid var(--teal-border);
  padding: 28px 0; overflow: hidden;
}
.logos-label-row {
  text-align: center; font-size: 11px; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; color: var(--text-muted); margin-bottom: 20px;
}
.ticker-wrapper { overflow: hidden; position: relative; }
.ticker-wrapper::before, .ticker-wrapper::after {
  content: ''; position: absolute; top: 0; bottom: 0; width: 80px; z-index: 2; pointer-events: none;
}
.ticker-wrapper::before { left: 0; background: linear-gradient(to right, var(--page-green), transparent); }
.ticker-wrapper::after { right: 0; background: linear-gradient(to left, var(--page-green), transparent); }

.ticker-track {
  display: flex; gap: 0; width: max-content;
  animation: ticker 40s linear infinite;
}
.ticker-track:hover { animation-play-state: paused; }
@keyframes ticker { 0%{ transform: translateX(0) } 100%{ transform: translateX(-50%) } }

.ticker-item {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  padding: 8px 28px; flex-shrink: 0;
  filter: grayscale(1) opacity(0.55);
  transition: filter .2s;
}
.ticker-item:hover { filter: grayscale(0) opacity(1); }
.ticker-logo {
  width: 28px; height: 28px; border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 800; color: var(--white); flex-shrink: 0;
}
.ticker-name { font-size: 13px; font-weight: 700; color: var(--navy); white-space: nowrap; }

/* SERVICES */
.services { background: var(--white); padding: 90px 60px; }
.section-inner { max-width: 1200px; margin: 0 auto; }
.section-label {
  font-size: 11px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--teal); text-align: center; margin-bottom: 14px;
}
.section-title {
  font-size: clamp(26px,3.5vw,34px); font-weight: 800; color: var(--navy);
  text-align: center; letter-spacing: -0.5px; margin-bottom: 12px; line-height: 1.2;
}
.section-sub {
  font-size: 16px; color: var(--text-muted);
  text-align: center; line-height: 1.7; max-width: 540px; margin: 0 auto 56px;
}
.cards-grid {
  display: grid; grid-template-columns: repeat(2,1fr); gap: 24px;
  max-width: 980px; margin: 0 auto;
}
.card {
  background: var(--white); border: 1px solid var(--teal-border);
  border-radius: 16px; padding: 32px 28px;
  transition: box-shadow .25s, border-color .25s, transform .2s;
  position: relative; overflow: hidden;
}
.card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: var(--cta-grad); opacity: 0; transition: opacity .25s;
}
.card:hover { box-shadow: 0 12px 48px rgba(0,200,150,.12); border-color: rgba(0,200,150,.3); transform: translateY(-3px); }
.card:hover::before { opacity: 1; }
.card-header { display: flex; align-items: flex-start; gap: 16px; margin-bottom: 16px; }
.card-icon {
  width: 50px; height: 50px; background: var(--pale-teal); border-radius: 12px;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 22px;
}
.card-top h3 { font-size: 17px; font-weight: 800; color: var(--navy); margin-bottom: 6px; }
.card-tags { display: flex; gap: 6px; flex-wrap: wrap; }
.tag {
  font-size: 9px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
  color: var(--green-dark); background: var(--pale-teal); padding: 3px 10px; border-radius: 99px;
}
.tag-addon { background: #fef3c7; color: #92400e; }
.card-body { font-size: 14px; color: var(--text-muted); line-height: 1.75; margin-bottom: 18px; }
.card-bullets { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.card-bullets li {
  font-size: 13px; color: #3A6070; line-height: 1.5; padding-left: 22px; position: relative;
}
.card-bullets li::before { content: '✓'; position: absolute; left: 0; color: var(--teal); font-weight: 700; }

/* ADD-ON CARDS */
.addon-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 24px; max-width: 980px; margin: 32px auto 0; }
.addon-card {
  background: var(--page-green); border: 1px dashed var(--teal-dark);
  border-radius: 16px; padding: 28px; position: relative;
}
.addon-badge {
  display: inline-block; font-size: 9px; font-weight: 700; letter-spacing: 1.5px;
  text-transform: uppercase; background: var(--teal); color: var(--navy-deep);
  padding: 3px 10px; border-radius: 99px; margin-bottom: 14px;
}
.addon-card h3 { font-size: 16px; font-weight: 800; color: var(--navy); margin-bottom: 10px; }
.addon-card p { font-size: 14px; color: var(--text-muted); line-height: 1.7; }

/* FEATURE STRIP */
.features-strip { background: var(--navy); padding: 60px; }
.features-strip-inner {
  max-width: 1000px; margin: 0 auto;
  display: grid; grid-template-columns: repeat(4,1fr); gap: 32px;
}
.feature-item { text-align: center; }
.feature-icon { font-size: 28px; margin-bottom: 12px; display: block; }
.feature-item h4 { font-size: 14px; font-weight: 700; color: var(--white); margin-bottom: 8px; }
.feature-item p { font-size: 12.5px; color: rgba(255,255,255,0.4); line-height: 1.6; }

/* HOW IT WORKS */
.how-it-works { background: var(--page-green); padding: 90px 60px; }
.steps-grid {
  display: grid; grid-template-columns: repeat(3,1fr); gap: 40px;
  max-width: 860px; margin: 0 auto; position: relative;
}
.steps-grid::before {
  content: ''; position: absolute;
  top: 26px; left: calc(16.66% + 10px);
  width: calc(66.66% - 20px); height: 2px;
  background: linear-gradient(90deg, var(--teal-border), var(--teal), var(--teal-border)); z-index: 0;
}
.step { text-align: center; position: relative; z-index: 1; }
.step-circle {
  width: 52px; height: 52px; border-radius: 50%;
  background: var(--navy); color: var(--teal);
  font-size: 18px; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 20px; border: 3px solid var(--teal-border); z-index: 2; position: relative;
}
.step h3 { font-size: 15px; font-weight: 800; color: var(--navy); margin-bottom: 10px; }
.step p { font-size: 13.5px; color: var(--text-muted); line-height: 1.6; }

/* ZEN WORKS */
.zen-works { background: var(--white); padding: 90px 60px; }
.zen-steps {
  display: grid; grid-template-columns: repeat(4,1fr); gap: 32px;
  max-width: 1000px; margin: 0 auto; position: relative;
}
.zen-steps::before {
  content: ''; position: absolute; top: 24px; left: 12.5%; width: 75%; height: 2px;
  background: linear-gradient(90deg, var(--teal-border), var(--teal), var(--teal-border));
}
.zen-step { text-align: center; position: relative; z-index: 1; }
.zen-step-number {
  width: 48px; height: 48px; border-radius: 50%;
  background: var(--teal); color: var(--navy-deep);
  font-size: 16px; font-weight: 800;
  display: flex; align-items: center; justify-content: center; margin: 0 auto 18px;
}
.zen-step h4 { font-size: 14px; font-weight: 800; color: var(--navy); margin-bottom: 8px; }
.zen-step p { font-size: 13px; color: var(--text-muted); line-height: 1.6; }

/* INDUSTRY SELECTOR */
.industry-selector { background: var(--page-green); padding: 90px 60px; }
.industry-inner { max-width: 740px; margin: 0 auto; }
.industry-tabs {
  display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-bottom: 40px;
}
.industry-tab {
  font-family: var(--font); font-size: 13px; font-weight: 600;
  padding: 8px 18px; border-radius: 99px; border: 1px solid var(--teal-border);
  background: var(--white); color: var(--text-muted); cursor: pointer; transition: all .2s;
}
.industry-tab.active, .industry-tab:hover {
  background: var(--teal); color: var(--navy-deep); border-color: var(--teal);
}
.industry-form {
  background: var(--white); border: 1px solid var(--teal-border);
  border-radius: 20px; padding: 40px;
}
.industry-form h3 { font-size: 22px; font-weight: 800; color: var(--navy); margin-bottom: 8px; }
.selected-industry { font-size: 13px; color: var(--teal); font-weight: 600; margin-bottom: 28px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
.form-group label { font-size: 13px; font-weight: 600; color: var(--navy); }
.form-group label span { color: #e53e3e; }
.form-group input {
  font-family: var(--font); font-size: 14px; padding: 12px 16px;
  border: 1px solid var(--teal-border); border-radius: 8px; outline: none;
  transition: border-color .2s;
}
.form-group input:focus { border-color: var(--teal); }
.form-submit {
  width: 100%; font-family: var(--font); font-size: 15px; font-weight: 700;
  background: var(--teal); color: var(--navy-deep); border: none; cursor: pointer;
  padding: 15px; border-radius: 8px; transition: opacity .2s, transform .15s; margin-top: 8px;
}
.form-submit:hover { opacity: .88; transform: translateY(-1px); }
.form-disclaimer { font-size: 12px; color: var(--text-muted); text-align: center; margin-top: 12px; }

/* TESTIMONIALS */
.results { background: var(--white); padding: 90px 60px; }
.testimonials-grid {
  display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; max-width: 1000px; margin: 0 auto 48px;
}
.testimonial-card {
  background: var(--white); border: 1px solid var(--teal-border);
  border-radius: 16px; padding: 28px; transition: transform .2s;
}
.testimonial-card:hover { transform: translateY(-3px); box-shadow: 0 12px 36px rgba(0,200,150,.08); }
.stars { color: var(--teal); font-size: 14px; margin-bottom: 14px; letter-spacing: 2px; }
.testimonial-quote {
  font-size: 14px; color: var(--navy); line-height: 1.7; font-weight: 500;
  margin-bottom: 20px; font-style: italic;
}
.testimonial-author { display: flex; align-items: center; gap: 12px; }
.author-avatar {
  width: 40px; height: 40px; border-radius: 50%; background: var(--pale-teal);
  display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 700;
  color: var(--green-dark); flex-shrink: 0;
}
.author-name { font-size: 13px; font-weight: 700; color: var(--navy); display: block; }
.author-role { font-size: 12px; color: var(--text-muted); }

