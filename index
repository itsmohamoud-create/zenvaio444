<script>
// Scroll reveal
const reveals = document.querySelectorAll('.reveal');
const revealObs = new IntersectionObserver((entries) => {
  entries.forEach((entry, i) => {
    if (entry.isIntersecting) {
      setTimeout(() => entry.target.classList.add('visible'), i * 80);
      revealObs.unobserve(entry.target);
    }
  });
}, { threshold: 0.1 });
reveals.forEach(el => revealObs.observe(el));

// Scroll top + sticky mobile CTA
let heroCTABottom = 0;
window.addEventListener('load', () => {
  const heroBtn = document.querySelector('.hero-btns');
  if (heroBtn) heroCTABottom = heroBtn.getBoundingClientRect().bottom + window.scrollY;
});
window.addEventListener('scroll', () => {
  const scrollTop = document.getElementById('scrollTop');
  const stickyMobile = document.getElementById('stickyMobile');
  if (window.scrollY > 500) scrollTop.classList.add('visible');
  else scrollTop.classList.remove('visible');
  if (window.innerWidth <= 768 && window.scrollY > (heroCTABottom || 300)) {
    stickyMobile.style.display = 'block';
  } else {
    stickyMobile.style.display = 'none';
  }
});

// Rotating testimonials
let currentTestimonial = 0;
const testimonialCards = document.querySelectorAll('.rotating-card');
const testimonialDots = document.querySelectorAll('.rotating-dot');
function goToTestimonial(index) {
  testimonialCards.forEach(c => c.classList.remove('active'));
  testimonialDots.forEach(d => d.classList.remove('active'));
  testimonialCards[index].classList.add('active');
  testimonialDots[index].classList.add('active');
  currentTestimonial = index;
}
setInterval(() => goToTestimonial((currentTestimonial + 1) % testimonialCards.length), 5000);

// Industry selector
function selectIndustry(btn, industry, desc) {
  document.querySelectorAll('.industry-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('selectedIndustry').textContent = 'Selected: ' + industry + ' — ' + desc;
}

// ROI Calculator
function updateROI() {
  const monthlyCalls = parseInt(document.getElementById('monthlyCalls').value);
  const missedRate = parseInt(document.getElementById('missedRate').value);
  const conversionRate = parseInt(document.getElementById('conversionRate').value);
  const customerValue = parseInt(document.getElementById('customerValue').value);
  document.getElementById('monthlyCallsVal').textContent = monthlyCalls.toLocaleString();
  document.getElementById('missedRateVal').textContent = missedRate + '%';
  document.getElementById('conversionRateVal').textContent = conversionRate + '%';
  document.getElementById('customerValueVal').textContent = '$' + customerValue.toLocaleString();
  const missed = Math.round(monthlyCalls * (missedRate / 100));
  const lostConv = Math.round(missed * (conversionRate / 100));
  const revLost = lostConv * customerValue;
  document.getElementById('missedPerMonth').textContent = missed.toLocaleString();
  document.getElementById('lostConversions').textContent = lostConv.toLocaleString();
  document.getElementById('revenueLost').textContent = '$' + revLost.toLocaleString();
  document.getElementById('yearlyRevenue').textContent = '+$' + revLost.toLocaleString() + '/mo';
  document.getElementById('yearlyTotal').textContent = '$' + (revLost * 12).toLocaleString() + ' / year';
}
updateROI();

// FAQ toggle
function toggleFAQ(el) {
  el.parentElement.classList.toggle('open');
}
</script>
